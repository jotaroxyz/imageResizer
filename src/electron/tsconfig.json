{
  "compilerOptions": {
    "rootDir": ".",
    "strict": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "outDir": "../../dist/electron",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": true,

    "composite": true,
    "declaration": true,
    "declarationMap": true
  }
}
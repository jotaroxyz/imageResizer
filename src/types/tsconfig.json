{
  "compilerOptions": {
    "rootDir": ".",
    "strict": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "outDir": "../../dist/types",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": true,

    "composite": true,
    "declaration": true,
    "declarationMap": true,
  },
  "include": ["**/*.ts", "**/*.d.ts"]
}
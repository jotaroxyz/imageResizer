{
  "appId": "com.jotaroxyz.imageResizer",
  "productName": "ImageResizer",
  "directories": {
    "output": "package"
  },
  "files": [
    "package.json",
    {
      "from": "dist/electron",
      "to": "dist/electron"
    },
    {
      "from": "dist/react",
      "to": "dist/react"
    }
  ],
  "icon": "./icon.png",
  "extraResources": [ "dist/electron/preload.cjs" ],
  "publish": {
    "provider": "github",
    "owner": "jotaroxyz",
    "repo": "imageResizer",
    "publishAutoUpdate": false
  },
  "mac": {
    "target": "dmg",
    "artifactName": "${productName}-${arch}.${ext}"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "artifactName": "${productName}.${ext}"
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "msi",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${target}.${ext}"
  }
}